    <string name="guided_onboarding_language_message">Siin saad muuta rakenduse keelt. Inglise keel on kõige kindlam viide, kui tõlge tundub ebakindel.</string>
    <string name="guided_onboarding_fandom_title">Fandom Wiki</string>
    <string name="guided_onboarding_fandom_message">See nupp avab Valheim Wiki allika, kust saad lugeda rohkem mängu ja rakenduses kasutatud andmete kohta.</string>
